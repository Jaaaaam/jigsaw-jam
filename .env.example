# Multiplayer (optional) — run `npx convex dev` and paste the deployment URL.
# Without it the app runs in full-featured solo mode.
VITE_CONVEX_URL=
# Set to "false" to disable multiplayer entirely (no Convex requests); remove or set "true" to re-enable.
VITE_MULTIPLAYER_ENABLED=

# Image providers (optional) — the app falls back to keyless Picsum without them.
# Pexels: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/
VITE_PIXABAY_API_KEY=
